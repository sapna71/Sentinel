
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT-4o-mini) — Secondary failover provider
OPENAI_API_KEY=your_openai_api_key_here

# TrueFoundry AI Gateway (optional — wraps all providers)
# If set, all requests route through the gateway instead of direct API calls
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_GATEWAY_URL=

# Ollama (Local Llama) — Tertiary emergency provider
# Run: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# MODEL CONFIGURATION
# ============================================================

PRIMARY_MODEL=claude-3-5-sonnet-20241022
SECONDARY_MODEL=gpt-4o-mini
TERTIARY_MODEL=llama3.1

# ============================================================
# RESILIENCE CONFIGURATION
# ============================================================

# Max retries before failover (per provider)
MAX_RETRIES=2

# Base delay for exponential backoff (seconds)
RETRY_BASE_DELAY=1.0

# Max delay cap for backoff (seconds)
RETRY_MAX_DELAY=10.0

# Request timeout (seconds)
REQUEST_TIMEOUT=30.0

# Circuit breaker: failures before opening
CIRCUIT_BREAKER_THRESHOLD=3

# Circuit breaker: seconds before attempting reset
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# ============================================================
# DATABASE
# ============================================================

DATABASE_URL=sqlite+aiosqlite:///./sentinel.db

# ============================================================
# SERVER
# ============================================================

HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ============================================================
# CORS (for Next.js frontend)
# ============================================================

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
